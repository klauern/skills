{
  "permissions": {
    "allow": [
      "Bash(claude plugin list:*)",
      "Bash(bd:*)",
      "Skill(commit)",
      "WebFetch(domain:agentskills.io)",
      "mcp__exa__get_code_context_exa",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "Bash(bunx @owloops/claude-powerline:*)",
      "Bash(bunx ccstatusline@latest:*)",
      "Bash(FORCE_COLOR=1 bunx ccstatusline@latest:*)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:developer.atlassian.com)",
      "Bash(acli:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:herocoders.atlassian.net)",
      "WebFetch(domain:marketplace.atlassian.com)",
      "WebFetch(domain:cursor.com)"
    ],
    "additionalDirectories": [
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-grep-extended.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-commit-format.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pr-quality-check.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/workflow-lint.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-validate-skill.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/version-bump-reminder.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/dev-context.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
